@model DiaryEntry
<div class="container mt-4">
    <div class="row">
        <div class="col-md-8 offset-md-2">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h2>Create Diary Entry</h2>
                </div>
                <div class="card-body">
                    <form asp-action="Create" method="post">
                        <div asp-validation-summary="All" class="text-danger"></div>
                        <div class="form-group mb-3">
                            <label asp-for="Title" class="form-label">Title</label>
                            <input asp-for="Title" type="text" class="form-control" placeholder="Enter a title" />
                            <span asp-validation-for="Title" class="text-danger mt-1"></span>
                        </div>
                        <div class="form-group mb-3">
                            <label asp-for="Content" class="form-label">Content</label>
                            <textarea asp-for="Content" class="form-control" placeholder="Enter what you did that day"
                                      rows="5"></textarea>
                            <span asp-validation-for="Content" class="text-danger mt-1"></span>
                        </div>
                        <div class="form-group mb-3">
                            <label asp-for="Created" class="form-label">Date</label>
                            <input asp-for="Created" type="datetime-local" class="form-control" />
                            <span asp-validation-for="Created" class="text-danger mt-1"></span>
                        </div>
                        <div class="d-flex justify-content-between">
                            <button type="submit" class="btn btn-primary">
                                Create
                            </button>
                            <a asp-controller="DiaryEntries" asp-action="Index" class="btn btn-danger">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>


@section Scripts {
    @* this will add the validation scripts to the page, so that when we add validation to our model, the client side
validation will work as well. *@
    <partial name="_ValidationScriptsPartial" />
}


